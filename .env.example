# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=gabaritoac.com.br,www.gabaritoac.com.br,gabarito.acrenets.com

# Database engine: "postgresql" or "mysql"
DATABASE_ENGINE=postgresql

# PostgreSQL (used when DATABASE_ENGINE=postgresql)
POSTGRES_DB=gabaritoac
POSTGRES_USER=gabaritoac
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
# POSTGRES_CONN_MAX_AGE=60
# POSTGRES_SSLMODE=prefer

# MySQL (used when DATABASE_ENGINE=mysql)
# MYSQL_DB=gabaritoac
# MYSQL_USER=gabaritoac
# MYSQL_PASSWORD=
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_CONN_MAX_AGE=60

# Wagtail
WAGTAILADMIN_BASE_URL=https://gabaritoac.com.br

# Email (SMTP / SendGrid)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key

# Logging
# DJANGO_LOG_LEVEL=INFO